---
import Layout from '../layouts/Layout.astro';

const dreams = [
  { num: '01', title: '一起看一次极光', desc: '在冰岛或挪威的夜空下，等待那一抹绿光', status: '未开始' },
  { num: '02', title: '学做一道完美的甜点', desc: '一起在厨房里手忙脚乱，然后分享成果', status: '未开始' },
  { num: '03', title: '养一只小猫', desc: '给我们的家添一个毛茸茸的新成员', status: '未开始' },
  { num: '04', title: '完成一次马拉松', desc: '不论快慢，一起跑过终点线', status: '未开始' },
  { num: '05', title: '去日本看樱花', desc: '在樱花树下野餐，感受春天的浪漫', status: '未开始' },
  { num: '06', title: '一起拍一部短片', desc: '记录我们的日常，剪成一个温暖的故事', status: '未开始' },
  { num: '07', title: '在海边看一次日出', desc: '早起是值得的，如果身边有你', status: '未开始' },
  { num: '08', title: '一起学一门新语言', desc: '也许是法语，也许是意大利语', status: '未开始' },
  { num: '09', title: '去十个新的国家', desc: '继续探索这个世界，收集新的回忆', status: '进行中' },
  { num: '10', title: '建一个温暖的家', desc: '不需要很大，但一定要有爱和阳光', status: '进行中' },
];

const timeline = [
  { place: '巴黎', title: '求婚', desc: '在巴黎的街头，开启了我们人生的新篇章', label: '求婚照片' },
  { place: '巴黎', title: '婚纱摄影', desc: '在光之城留下我们最美的瞬间', label: '婚纱照' },
  { place: '里斯本', title: '旅拍', desc: '在里斯本的阳光下，记录我们的爱情故事', label: '情侣照' },
  { place: '香港', title: '婚姻注册', desc: '在香港正式注册，携手成为彼此的家人', label: '注册照片' },
];
---

<Layout title="江纯 & 徐正扬 · 婚礼邀请">

  <nav class="nav">
    <div class="nav-inner">
      <a href="#home" class="nav-logo">纯 & 扬</a>
      <div class="nav-links">
        <a href="#journey">故事</a>
        <a href="#wedding">婚礼</a>
        <a href="#dreams">愿望</a>
        <a href="#gifts">手作</a>
      </div>
    </div>
  </nav>

  <section id="home" class="hero">
    <div class="hero-content">
      <p class="hero-subtitle">婚 礼 邀 请 函</p>
      <div class="hero-video">
        <div class="video-placeholder">
          <div class="play-icon">▶</div>
          <p>视频邀请函即将上线</p>
        </div>
      </div>
      <div class="hero-names">
        <span class="bride">江纯</span>
        <span class="ampersand">&</span>
        <span class="groom">徐正扬</span>
      </div>
      <p class="hero-date">2026 · 05 · 30</p>
      <div class="scroll-hint">
        <span>向下滑动</span>
        <div class="scroll-arrow">↓</div>
      </div>
    </div>
  </section>

  <section id="journey" class="section">
    <div class="container">
      <div class="section-header">
        <h2>我们的故事</h2>
        <p class="section-subtitle">世间所有的相遇，都是久别重逢</p>
      </div>
      <div class="timeline">
        {timeline.map((item) => (
          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-image placeholder-image">
                <span>{item.label}</span>
              </div>
              <div class="timeline-text">
                <span class="timeline-date">{item.place}</span>
                <h3>{item.title}</h3>
                <p>{item.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="wedding" class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2>婚礼详情</h2>
        <p class="section-subtitle">诚挚邀请您共同见证我们的幸福时刻</p>
      </div>
      <div class="wedding-card">
        <div class="wedding-info">
          <div class="info-item">
            <span class="info-label">日期</span>
            <span class="info-value">2026年5月30日 星期六</span>
          </div>
          <div class="info-item">
            <span class="info-label">地点</span>
            <span class="info-value">上海波特曼丽思卡尔顿酒店 宴会厅</span>
          </div>
          <div class="info-item">
            <span class="info-label">地址</span>
            <span class="info-value">上海市静安区南京西路1376号</span>
          </div>
        </div>
        <div class="schedule">
          <h3>流 程</h3>
          <div class="schedule-item">
            <span class="time">16:33</span>
            <div class="schedule-line"></div>
            <div class="schedule-detail">
              <h4>签到 & 互动</h4>
              <p>一场浪漫的、暖暖的迎宾仪式</p>
            </div>
          </div>
          <div class="schedule-item">
            <span class="time">18:09</span>
            <div class="schedule-line"></div>
            <div class="schedule-detail">
              <h4>仪式 & 宴席</h4>
              <p>一起分享这终生中最美的旅程</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="dreams" class="section">
    <div class="container">
      <div class="section-header">
        <h2>我们的愿望清单</h2>
        <p class="section-subtitle">婚后想要一起完成的十件事</p>
      </div>
      <div class="dreams-grid">
        {dreams.map((dream) => (
          <div class="dream-card">
            <span class="dream-num">{dream.num}</span>
            <h3>{dream.title}</h3>
            <p>{dream.desc}</p>
            <span class:list={['dream-status', { 'in-progress': dream.status === '进行中', 'completed': dream.status === '已完成' }]}>
              {dream.status}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="gifts" class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2>手作伴手礼</h2>
        <p class="section-subtitle">我们亲手制作的陶艺，送给每一位到场的你</p>
      </div>
      <div class="gifts-intro">
        <p>我们一起学习陶艺，亲手为每一位来宾制作独一无二的婚礼伴手礼。每一件作品都承载着我们的心意，希望这份温度能传递到你手中。</p>
      </div>
      <div class="gifts-gallery">
        {[1, 2, 3, 4, 5, 6].map((i) => (
          <div class="gallery-item placeholder-image">
            <span>制作过程 {i}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <p class="footer-names">江纯 & 徐正扬</p>
      <p class="footer-date">2026 · 05 · 30</p>
      <p class="footer-message">期待，婚礼相见</p>
    </div>
  </footer>

</Layout>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(245, 240, 232, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid #D4C5B0;
  }
  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .nav-logo {
    font-weight: 600;
    font-size: 1.1rem;
    letter-spacing: 2px;
    color: #B8A088;
  }
  .nav-links {
    display: flex;
    gap: 32px;
  }
  .nav-links a {
    font-size: 0.85rem;
    color: #7A7268;
    transition: color 0.3s;
    letter-spacing: 1px;
  }
  .nav-links a:hover {
    color: #3A3530;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .section {
    padding: 100px 0;
  }
  .section-alt {
    background: #EDE7DB;
  }
  .section-header {
    text-align: center;
    margin-bottom: 64px;
  }
  .section-header h2 {
    font-size: 1.8rem;
    font-weight: 600;
    margin-bottom: 12px;
    letter-spacing: 4px;
  }
  .section-subtitle {
    font-size: 0.9rem;
    color: #7A7268;
    letter-spacing: 2px;
  }
  .placeholder-image {
    background: #E8DFD0;
    border: 1px dashed #C9BEA8;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #B8A088;
    font-size: 0.85rem;
    min-height: 200px;
  }

  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 24px 40px;
  }
  .hero-content {
    text-align: center;
    max-width: 600px;
    width: 100%;
  }
  .hero-subtitle {
    font-size: 0.85rem;
    letter-spacing: 6px;
    color: #B8A088;
    margin-bottom: 40px;
  }
  .hero-video {
    margin-bottom: 48px;
  }
  .video-placeholder {
    aspect-ratio: 16/9;
    background: #EDE7DB;
    border: 1px dashed #C9BEA8;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    color: #B8A088;
  }
  .play-icon {
    width: 60px;
    height: 60px;
    border: 2px solid #B8A088;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
  }
  .hero-names {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    margin-bottom: 16px;
  }
  .bride, .groom {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: 8px;
  }
  .ampersand {
    font-size: 1.5rem;
    color: #B8A088;
    font-style: italic;
  }
  .hero-date {
    font-size: 1rem;
    letter-spacing: 8px;
    color: #7A7268;
    margin-bottom: 60px;
  }
  .scroll-hint {
    color: #B8A088;
    font-size: 0.75rem;
    letter-spacing: 3px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    animation: bounce 2s infinite;
  }
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  .timeline {
    position: relative;
    padding-left: 40px;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 8px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: #D4C5B0;
  }
  .timeline-item {
    position: relative;
    margin-bottom: 64px;
  }
  .timeline-item:last-child {
    margin-bottom: 0;
  }
  .timeline-dot {
    position: absolute;
    left: -36px;
    top: 8px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #B8A088;
    border: 3px solid #F5F0E8;
  }
  .timeline-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
  }
  .timeline-image {
    aspect-ratio: 4/3;
    border-radius: 4px;
    overflow: hidden;
  }
  .timeline-date {
    font-size: 0.75rem;
    letter-spacing: 4px;
    color: #B8A088;
  }
  .timeline-text h3 {
    font-size: 1.3rem;
    font-weight: 600;
    margin: 8px 0;
    letter-spacing: 2px;
  }
  .timeline-text p {
    font-size: 0.9rem;
    color: #7A7268;
    line-height: 1.8;
  }

  .wedding-card {
    background: rgba(245, 240, 232, 0.6);
    padding: 48px;
    border: 1px solid #D4C5B0;
    border-radius: 4px;
  }
  .wedding-info {
    margin-bottom: 48px;
  }
  .info-item {
    display: flex;
    padding: 16px 0;
    border-bottom: 1px solid #D4C5B0;
  }
  .info-label {
    width: 80px;
    flex-shrink: 0;
    font-size: 0.8rem;
    letter-spacing: 3px;
    color: #B8A088;
    padding-top: 2px;
  }
  .info-value {
    font-size: 0.95rem;
  }
  .schedule h3 {
    font-size: 1.1rem;
    letter-spacing: 4px;
    margin-bottom: 32px;
    text-align: center;
    color: #B8A088;
  }
  .schedule-item {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    margin-bottom: 32px;
  }
  .time {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: 2px;
    flex-shrink: 0;
    width: 80px;
    color: #3A3530;
  }
  .schedule-line {
    width: 40px;
    height: 1px;
    background: #D4C5B0;
    margin-top: 16px;
    flex-shrink: 0;
  }
  .schedule-detail h4 {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 2px;
    margin-bottom: 4px;
  }
  .schedule-detail p {
    font-size: 0.85rem;
    color: #7A7268;
  }

  .dreams-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .dream-card {
    background: #EDE7DB;
    padding: 32px;
    border-radius: 4px;
    transition: transform 0.3s;
  }
  .dream-card:hover {
    transform: translateY(-4px);
  }
  .dream-num {
    font-size: 2rem;
    font-weight: 200;
    color: #D4C5B0;
    line-height: 1;
    margin-bottom: 12px;
    display: block;
  }
  .dream-card h3 {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 1px;
    margin-bottom: 8px;
  }
  .dream-card p {
    font-size: 0.85rem;
    color: #7A7268;
    line-height: 1.6;
    margin-bottom: 16px;
  }
  .dream-status {
    font-size: 0.7rem;
    letter-spacing: 2px;
    padding: 4px 12px;
    background: #D4C5B0;
    color: #7A7268;
    border-radius: 2px;
  }
  .dream-status.in-progress {
    background: #B8A088;
    color: #F5F0E8;
  }
  .dream-status.completed {
    background: #8B9E7E;
    color: #F5F0E8;
  }

  .gifts-intro {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 48px;
    font-size: 0.9rem;
    color: #7A7268;
    line-height: 2;
  }
  .gifts-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .gallery-item {
    aspect-ratio: 1;
    border-radius: 4px;
    overflow: hidden;
  }

  .footer {
    padding: 80px 0;
    text-align: center;
  }
  .footer-names {
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: 6px;
    margin-bottom: 8px;
  }
  .footer-date {
    font-size: 0.85rem;
    letter-spacing: 6px;
    color: #B8A088;
    margin-bottom: 24px;
  }
  .footer-message {
    font-family: 'Ma Shan Zheng', cursive;
    font-size: 1.5rem;
    color: #7A7268;
  }

  @media (max-width: 768px) {
    .nav-links { gap: 16px; }
    .nav-links a { font-size: 0.75rem; }
    .section { padding: 64px 0; }
    .section-header { margin-bottom: 40px; }
    .section-header h2 { font-size: 1.4rem; }
    .bride, .groom { font-size: 1.5rem; letter-spacing: 4px; }
    .timeline-content { grid-template-columns: 1fr; }
    .wedding-card { padding: 24px; }
    .info-item { flex-direction: column; gap: 4px; }
    .info-label { width: auto; }
    .schedule-item { flex-wrap: wrap; }
    .dreams-grid { grid-template-columns: 1fr; }
    .gifts-gallery { grid-template-columns: repeat(2, 1fr); }
  }
</style>
